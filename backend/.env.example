PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/storachain
JWT_SECRET=your-64-char-random-hex-secret-here
PINATA_JWT=your-pinata-jwt-here
PINATA_API_KEY=your-pinata-api-key-here
PINATA_API_SECRET=your-pinata-api-secret-here
GATEWAY_URL=your-subdomain.mypinata.cloud
TOKEN_CONTRACT_ADDRESS=0x_StoraToken_deployed_address
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your-deployer-wallet-private-key
BACKEND_AGENT_KEY=shared-secret-between-backend-and-agents
AI_SERVICE_URL=http://localhost:5001
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your-64-hex-char-aes-master-key-here
# Set to 2 for local testing; leave at 60 (or omit) for production
REPLICATION_INTERVAL_MINUTES=60

# ─── Provider System (CLI Installation & Earnings) ───
# Provider registration endpoint URL
PROVIDER_REGISTRATION_BACKEND_URL=http://localhost:5000
# Auto-mint tokens to providers on registration (set to true to enable)
PROVIDER_AUTO_MINT_ENABLED=true
# Token amounts for bonuses (in SCT, with decimals)
PROVIDER_REGISTRATION_BONUS=0.1
PROVIDER_ONLINE_BONUS=0.2
