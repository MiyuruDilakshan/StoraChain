# StoraChain Provider Agent — Environment Configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────
# Your Ethereum wallet address (used to receive SCT token rewards)
WALLET_ADDRESS=0xYourWalletAddressHere

# ── Auto-Registration ────────────────────────────────────────────────────
# JWT token from your StoraChain account login.
# If set, the agent auto-registers on startup and sends heartbeats.
# How to get it: Log in at StoraChain → open browser DevTools →
# Application → Local Storage → copy the "token" value
AGENT_JWT=

# ── StoraChain Backend ───────────────────────────────────────────────────
# URL of the StoraChain backend server
BACKEND_URL=http://localhost:5000

# Shared secret key for backend→agent authentication
# MUST match BACKEND_AGENT_KEY in the backend .env
BACKEND_AGENT_KEY=agent-secret-key

# ── Storage Settings ─────────────────────────────────────────────────────
# Directory where encrypted chunks are stored (default: ./storachain-storage)
STORAGE_DIR=./storachain-storage

# Geographic region label (e.g. EU, US-East, Asia, local)
REGION=local
